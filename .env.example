# Example environment file for patchmgr.
# Copy to ".env" and fill in the values you actually want to use.
# Never commit your real .env file to version control.

# Optional API key for the NVD (National Vulnerability Database) 2.0 REST API.
# Without a key the public endpoint is heavily rate-limited (1 req / 6s).
# Request a free key at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Default credentials fallback used ONLY when --target does not include them.
# Format: username:password (no IP). Strongly recommended to leave blank and
# pass credentials at runtime via --password-stdin or a secrets manager.
PATCHMGR_DEFAULT_USER=
PATCHMGR_DEFAULT_PASSWORD=

# Where on-disk caches (NVD responses) live. Defaults to ~/.patchmgr/cache.
PATCHMGR_CACHE_DIR=

# Where run reports and logs are written. Defaults to ./reports.
PATCHMGR_REPORT_DIR=
